# ============================================
# My Barber — Variables de Entorno
# ============================================
# Copiá este archivo como .env.local y completá los valores.
# NUNCA commitear .env.local con valores reales.

# ---------- General ----------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Base de Datos (Neon) ----------
# Formato: postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://mybarber:password@ep-xxx.us-east-2.aws.neon.tech/mybarber?sslmode=require

# ---------- Better-Auth ----------
# Generar con: openssl rand -base64 32
BETTER_AUTH_SECRET=genera-un-string-aleatorio-de-32-caracteres-minimo
BETTER_AUTH_URL=http://localhost:3000

# ---------- MercadoPago ----------
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Secret para validar webhooks (configurar en panel de MP)
MERCADOPAGO_WEBHOOK_SECRET=tu-webhook-secret-configurado-en-mp
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------- Resend (Email) ----------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="My Barber <no-reply@tudominio.com>"

# ---------- Twilio (WhatsApp) ----------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---------- Sentry ----------
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
# Auth token para source maps (solo CI)
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# ---------- Cron Jobs ----------
# Secret para proteger endpoints de cron (Vercel Cron o similar)
CRON_SECRET=genera-un-string-aleatorio-para-cron

# ---------- Planes (precios en centavos ARS) ----------
# Estos valores también están en lib/constants.ts como fallback
PLAN_INDIVIDUAL_PRICE_CENTS=2499900
PLAN_BUSINESS_PRICE_CENTS=4799900
TRIAL_DAYS=14

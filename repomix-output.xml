  todaySalesCount: number;
  onDismiss: () => void;
}

export function SaleSuccess({
  amount,
  todayTotal,
  todaySalesCount,
  onDismiss,
}: SaleSuccessProps) {
  const router = useRouter();

  // Auto-dismiss after 2s
  React.useEffect(() => {
    const timer = setTimeout(onDismiss, 2000);
    return () => clearTimeout(timer);
  }, [onDismiss]);

  return (
    <button
      type="button"

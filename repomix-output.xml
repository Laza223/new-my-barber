        </h3>
        <p className="text-muted-foreground py-8 text-center text-sm">
          Sin datos todavía
        </p>
      </div>
    );
  }

  return (
    <div className="bg-card rounded-xl border p-5">
      <h3 className="text-muted-foreground mb-4 text-sm font-medium">

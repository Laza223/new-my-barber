- Configurar alerta si el tiempo de respuesta supera 3 segundos

---

### 11.4 Logs y Debugging en Producción

```typescript
// lib/logger.ts
// En producción, nunca usar console.log directamente
// Usar un logger que incluya contexto y timestamps

export const logger = {
  info: (message: string, meta?: object) => {
    if (process.env.NODE_ENV === 'production') {
      console.log(
        JSON.stringify({
          level: 'info',
          message,
          ...meta,
          ts: new Date().toISOString(),
        }),
      );
    } else {
      console.log(`[INFO] ${message}`, meta || '');
    }
  },
  error: (message: string, error?: Error, meta?: object) => {
    console.error(
      JSON.stringify({
        level: 'error',
        message,
        error: error?.message,
        stack: error?.stack,
        ...meta,
        ts: new Date().toISOString(),
      }),
    );
    // También reportar a Sentry:
    if (error) Sentry.captureException(error, { extra: meta });
  },
};
```


                    return (
                      <div
                        key={sale.id}
                        className="grid grid-cols-[3rem_1fr_3.5rem_4rem] items-center gap-3 px-2 py-1.5 md:grid-cols-[3.5rem_1fr_6rem_5rem] md:gap-4 md:px-3 md:py-2"
